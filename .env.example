# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENCODE_API_KEY: Required for OpenCode AI API calls.
# Get your key at https://opencode.ai/auth
OPENCODE_API_KEY="MY_OPENCODE_API_KEY"

# OPENCODE_API_BASE_URL: API endpoint (Zen or Go).
# Zen (default): https://opencode.ai/zen/v1
# Go:            https://opencode.ai/zen/go/v1
OPENCODE_API_BASE_URL="https://opencode.ai/zen/v1"

# OPENCODE_MODEL: Model ID to use.
# Zen examples: gpt-5.4-mini, claude-sonnet-4-5, gemini-3-flash
# Go examples:  qwen3.5-plus, kimi-k2.5, glm-5
OPENCODE_MODEL="gpt-5.4-mini"

# ─── Web Search Configuration ───
# SEARCH_BACKEND: Which search backend to use.
# Options: duckduckgo (default, may show CAPTCHA), brave, searxng, mock
# - duckduckgo: Free, no API key. Uses DuckDuckGo Lite. May fail with CAPTCHA
#   from residential IPs — works better from server IPs.
# - brave: Requires BRAVE_SEARCH_API_KEY. Free tier: 2000 queries/month.
#   Sign up at https://brave.com/search/api/ (2 min, no credit card).
# - searxng: Self-hosted SearXNG instance. Set SEARXNG_URL to your instance.
#   Example: http://localhost:8888
# - mock: Hardcoded sample results. For testing the tool pipeline only.
SEARCH_BACKEND="duckduckgo"

# BRAVE_SEARCH_API_KEY: API key for Brave Search (required for SEARCH_BACKEND=brave).
# Get your free key at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=""

# SEARXNG_URL: URL of your self-hosted SearXNG instance.
# Used when SEARCH_BACKEND=searxng, or auto-detected if set.
# Example: http://localhost:8888
SEARXNG_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
